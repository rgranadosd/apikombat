  "colors": {
    "state": {
      "sano": "#00A86B",
      "vacunado": "#50A0FF",
      "inmunizado": "#C0C0C0",
      "infecto": "#DC1E1E"
    }
  },
  "images": {
    "cardBack": "assets/cards/back.png",
    "organs": {
      "corazon": {
        "sano": "assets/cards/organo_corazon.png",
        "vacunado": "assets/cards/medicina_corazon.png",
        "inmunizado": "assets/cards/medicina_corazon.png",
        "infecto": "assets/cards/virus_corazon.png"
      },
      "cerebro": {
        "sano": "assets/cards/organo_cerebro.png",
        "vacunado": "assets/cards/medicina_cerebro.png",
        "inmunizado": "assets/cards/medicina_cerebro.png",
        "infecto": "assets/cards/virus_cerebro.png"
      },
      "huesos": {
        "sano": "assets/cards/organo_huesos.png",
        "vacunado": "assets/cards/medicina_huesos.png",
        "inmunizado": "assets/cards/medicina_huesos.png",
        "infecto": "assets/cards/virus_huesos.png"
      },
      "estomago": {
        "sano": "assets/cards/organo_estomago.png",
        "vacunado": "assets/cards/medicina_estomago.png",
        "inmunizado": "assets/cards/medicina_estomago.png",
        "infecto": "assets/cards/virus_estomago.png"
      },
      "multicolor": {
        "sano": "assets/cards/organo_multicolor.png",
        "vacunado": "assets/cards/medicina_multicolor.png",
