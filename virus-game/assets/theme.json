{
  "$schema": "https://example.com/virus-game/theme.schema.json",
  "meta": {
    "name": "default",
    "version": 1,
    "updatedAt": "2025-11-03"
  },
  "layout": {
    "card": { "width": 120, "height": 170 },
    "hand": { "gap": 160, "y": "bottom-90" },
    "slots": {
      "order": ["corazon", "cerebro", "huesos", "estomago"],
      "gap": 180,
      "yTop": 220,
      "yBottom": 460
    }
  },
  "fonts": {
    "large": { "name": "default", "size": 32 },
    "medium": { "name": "default", "size": 20 },
    "small": { "name": "default", "size": 14 }
